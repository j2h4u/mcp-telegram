{
  "steps": [
    {
      "_comment": "trace_account_messages is exposed with structured output schema",
      "action": "list_tools",
      "expect": {
        "tool_names_include": ["trace_account_messages"],
        "tool_expectations": {
          "trace_account_messages": {
            "title": "Account Trace",
            "outputSchema.properties.coverage.type": "object",
            "outputSchema.properties.provenance.properties.coverage_bounds.type": "object"
          }
        }
      }
    },
    {
      "_comment": "observed Account Trace smoke against MCP_TG_SMOKE_ACCOUNT",
      "action": "call_tool",
      "name": "trace_account_messages",
      "arguments": {
        "account": "${MCP_TG_SMOKE_ACCOUNT}",
        "coverage_goal": "observed",
        "limit": 5
      },
      "expect": {
        "is_error": false,
        "path_equals": {
          "structuredContent.resolved_account.confidence": "resolved",
          "structuredContent.provenance.coverage_goal": "observed",
          "structuredContent.result_count_semantics": "current_page_evidence_items"
        },
        "path_exists": [
          "structuredContent.resolved_account",
          "structuredContent.coverage",
          "structuredContent.groups",
          "structuredContent.provenance",
          "structuredContent.text_preview"
        ],
        "path_nonempty": [
          "structuredContent",
          "structuredContent.resolved_account",
          "structuredContent.coverage",
          "structuredContent.provenance",
          "content.0.text"
        ]
      }
    },
    {
      "_comment": "best_effort_visible Account Trace smoke remains bounded and provenance-rich",
      "action": "call_tool",
      "name": "trace_account_messages",
      "arguments": {
        "account": "${MCP_TG_SMOKE_ACCOUNT}",
        "coverage_goal": "best_effort_visible",
        "limit": 5
      },
      "expect": {
        "is_error": false,
        "path_equals": {
          "structuredContent.resolved_account.confidence": "resolved",
          "structuredContent.provenance.coverage_goal": "best_effort_visible",
          "structuredContent.provenance.enrichment.coverage_bounds.max_dialogs": 10,
          "structuredContent.provenance.enrichment.coverage_bounds.max_per_dialog": 100,
          "structuredContent.provenance.enrichment.coverage_bounds.deadline_ms": 15000
        },
        "path_exists": [
          "structuredContent.resolved_account",
          "structuredContent.coverage",
          "structuredContent.groups",
          "structuredContent.provenance",
          "structuredContent.text_preview"
        ],
        "path_nonempty": [
          "structuredContent",
          "structuredContent.resolved_account",
          "structuredContent.coverage",
          "structuredContent.provenance",
          "content.0.text"
        ]
      }
    },
    {
      "_comment": "unresolved account is a structured non-error domain outcome",
      "action": "call_tool",
      "name": "trace_account_messages",
      "arguments": {
        "account": "999999999999999",
        "coverage_goal": "observed",
        "limit": 5
      },
      "expect": {
        "is_error": false,
        "path_equals": {
          "structuredContent.resolved_account.confidence": "unresolved",
          "structuredContent.gaps.0.kind": "account_unresolved"
        },
        "path_exists": [
          "structuredContent.resolved_account",
          "structuredContent.gaps",
          "structuredContent.warnings",
          "structuredContent.provenance"
        ],
        "path_nonempty": [
          "structuredContent",
          "structuredContent.gaps",
          "structuredContent.warnings",
          "content.0.text"
        ]
      }
    }
  ]
}
