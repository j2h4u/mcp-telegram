{
  "steps": [
    {
      "_comment": "list_dialogs — returns real dialogs with metadata",
      "action": "call_tool",
      "name": "list_dialogs",
      "arguments": {},
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.dialogs",
          "structuredContent.count",
          "structuredContent.filters"
        ],
        "path_nonempty": [
          "structuredContent",
          "structuredContent.dialogs"
        ]
      }
    },
    {
      "_comment": "get_usage_stats — returns account-level usage stats",
      "action": "call_tool",
      "name": "get_usage_stats",
      "arguments": {},
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.total_calls",
          "structuredContent.tool_distribution"
        ],
        "path_nonempty": [
          "structuredContent"
        ]
      }
    },
    {
      "_comment": "list_topics — generic dialog lookup uses a non-personal placeholder",
      "action": "call_tool",
      "name": "list_topics",
      "arguments": {"dialog": "integration-smoke-placeholder"},
      "expect": {
        "one_of": [
          {
            "is_error": false,
            "path_equals": {
              "content": []
            },
            "path_exists": [
              "structuredContent.dialog",
              "structuredContent.topics",
              "structuredContent.count"
            ],
            "path_nonempty": [
              "structuredContent"
            ]
          },
          {
            "is_error": true,
            "content_text_contains": [
              "not found"
            ]
          }
        ]
      }
    },
    {
      "_comment": "search_messages — placeholder dialog id and neutral query",
      "action": "call_tool",
      "name": "search_messages",
      "arguments": {"dialog": "987654321", "query": "test", "limit": 3},
      "expect": {
        "one_of": [
          {
            "is_error": false,
            "path_equals": {
              "content": []
            },
            "path_exists": [
              "structuredContent.results",
              "structuredContent.count"
            ]
          },
          {
            "is_error": true,
            "content_text_contains": [
              "dialog"
            ]
          }
        ]
      }
    },
    {
      "_comment": "get_inbox — personal scope",
      "action": "call_tool",
      "name": "get_inbox",
      "arguments": {},
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.dialogs",
          "structuredContent.count",
          "structuredContent.coverage"
        ],
        "path_nonempty": [
          "structuredContent"
        ]
      }
    },
    {
      "_comment": "get_sync_status — returns structured status (synced or not_synced)",
      "action": "call_tool",
      "name": "get_sync_status",
      "arguments": {"dialog_id": 12345},
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.dialog_id",
          "structuredContent.status",
          "structuredContent.delete_detection"
        ],
        "path_nonempty": [
          "structuredContent",
          "structuredContent.status"
        ]
      }
    },
    {
      "_comment": "get_sync_alerts — returns alerts or 'No sync alerts'",
      "action": "call_tool",
      "name": "get_sync_alerts",
      "arguments": {"since": 0, "limit": 10},
      "expect": {
        "is_error": false,
        "path_exists": [
          "structuredContent.alerts",
          "structuredContent.count",
          "structuredContent.limited_by"
        ],
        "path_nonempty": [
          "structuredContent"
        ]
      }
    },
    {
      "_comment": "get_dialog_stats — placeholder dialog id validates the actionable error path",
      "action": "call_tool",
      "name": "get_dialog_stats",
      "arguments": {"dialog": "987654321", "top_n": 3},
      "expect": {
        "one_of": [
          {
            "is_error": true,
            "content_text_contains": [
              "synced"
            ]
          },
          {
            "is_error": true,
            "content_text_contains": [
              "dialog"
            ]
          }
        ]
      }
    },
    {
      "_comment": "get_my_recent_activity — own sent messages with time filters and reply counts",
      "action": "call_tool",
      "name": "get_my_recent_activity",
      "arguments": {
        "since_hours": 24,
        "limit": 50,
        "sent_after": "2000-01-01T00:00:00Z",
        "sent_before": "2100-01-01T00:00:00Z"
      },
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.scan_status",
          "structuredContent.comments",
          "structuredContent.count"
        ],
        "path_nonempty": [
          "structuredContent"
        ]
      }
    },
    {
      "_comment": "submit_feedback — live round-trip into feedback.db; hidden from default operator queue by context/harness marker",
      "action": "call_tool",
      "name": "submit_feedback",
      "arguments": {
        "message": "Automated MCP smoke test — please ignore",
        "severity": "question",
        "context": "smoke-integration.json automated test",
        "model": "claude-opus-4-7",
        "harness": "devtools.mcp_client.cli"
      },
      "expect": {
        "is_error": false,
        "path_equals": {
          "content": []
        },
        "path_exists": [
          "structuredContent.accepted",
          "structuredContent.status",
          "structuredContent.tracking_id"
        ],
        "path_nonempty": [
          "structuredContent.accepted",
          "structuredContent.status"
        ]
      }
    }
  ]
}
