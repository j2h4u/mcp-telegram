{
  "steps": [
    {
      "_comment": "All 14 tools registered with correct schemas",
      "action": "list_tools",
      "expect": {
        "tool_names_include": [
          "list_dialogs",
          "list_messages",
          "search_messages",
          "list_topics",
          "get_inbox",
          "get_entity_info",
          "get_usage_stats",
          "get_dialog_stats",
          "get_my_recent_activity",
          "mark_dialog_for_sync",
          "get_sync_status",
          "get_sync_alerts",
          "submit_feedback"
        ],
        "tool_expectations": {
          "list_messages": {
            "inputSchema.properties.limit.default": 50,
            "inputSchema.properties.navigation.type": "string"
          },
          "search_messages": {
            "inputSchema.properties.navigation.type": "string"
          },
          "mark_dialog_for_sync": {
            "inputSchema.properties.dialog_id.type": "integer",
            "inputSchema.properties.enable.default": true
          },
          "get_sync_status": {
            "inputSchema.properties.dialog_id.type": "integer"
          },
          "submit_feedback": {
            "inputSchema.properties.message.type": "string",
            "inputSchema.properties.message.maxLength": 10000
          }
        }
      }
    },

    {
      "_comment": "list_dialogs — daemon route",
      "action": "call_tool",
      "name": "list_dialogs",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "list_messages — daemon route",
      "action": "call_tool",
      "name": "list_messages",
      "arguments": {"dialog": "test", "limit": 1},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "search_messages — daemon route",
      "action": "call_tool",
      "name": "search_messages",
      "arguments": {"dialog": "test", "query": "hello", "limit": 1},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "list_topics — daemon route",
      "action": "call_tool",
      "name": "list_topics",
      "arguments": {"dialog": "test"},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "mark_dialog_for_sync — daemon route",
      "action": "call_tool",
      "name": "mark_dialog_for_sync",
      "arguments": {"dialog_id": 12345, "enable": true},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "get_sync_status — daemon route",
      "action": "call_tool",
      "name": "get_sync_status",
      "arguments": {"dialog_id": 12345},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "get_entity_info — resolve first, daemon not running so returns not-running message",
      "action": "call_tool",
      "name": "get_entity_info",
      "arguments": {"entity": "nonexistent_test_entity_12345"},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "get_inbox — daemon route",
      "action": "call_tool",
      "name": "get_inbox",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "get_usage_stats — analytics.db, works without daemon",
      "action": "call_tool",
      "name": "get_usage_stats",
      "arguments": {},
      "expect": {
        "is_error": false
      }
    },
    {
      "_comment": "submit_feedback — daemon route, fails gracefully when daemon is down",
      "action": "call_tool",
      "name": "submit_feedback",
      "arguments": {"message": "smoke test from no-daemon harness", "severity": "bug"},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    }
  ]
}
