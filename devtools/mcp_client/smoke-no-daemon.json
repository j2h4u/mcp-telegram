{
  "steps": [
    {
      "_comment": "All 13 tools registered with correct schemas",
      "action": "list_tools",
      "expect": {
        "tool_names_include": [
          "ListDialogs",
          "ListMessages",
          "SearchMessages",
          "ListTopics",
          "GetInbox",
          "GetMyAccount",
          "GetEntityInfo",
          "GetUsageStats",
          "GetDialogStats",
          "GetMyRecentActivity",
          "MarkDialogForSync",
          "GetSyncStatus",
          "GetSyncAlerts"
        ],
        "tool_expectations": {
          "ListMessages": {
            "inputSchema.properties.limit.default": 50,
            "inputSchema.properties.navigation.type": "string"
          },
          "SearchMessages": {
            "inputSchema.properties.navigation.type": "string"
          },
          "MarkDialogForSync": {
            "inputSchema.properties.dialog_id.type": "integer",
            "inputSchema.properties.enable.default": true
          },
          "GetSyncStatus": {
            "inputSchema.properties.dialog_id.type": "integer"
          }
        }
      }
    },

    {
      "_comment": "ListDialogs — daemon route",
      "action": "call_tool",
      "name": "ListDialogs",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "ListMessages — daemon route",
      "action": "call_tool",
      "name": "ListMessages",
      "arguments": {"dialog": "test", "limit": 1},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "SearchMessages — daemon route",
      "action": "call_tool",
      "name": "SearchMessages",
      "arguments": {"dialog": "test", "query": "hello", "limit": 1},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "ListTopics — daemon route",
      "action": "call_tool",
      "name": "ListTopics",
      "arguments": {"dialog": "test"},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "GetMyAccount — daemon route",
      "action": "call_tool",
      "name": "GetMyAccount",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "MarkDialogForSync — daemon route",
      "action": "call_tool",
      "name": "MarkDialogForSync",
      "arguments": {"dialog_id": 12345, "enable": true},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "GetSyncStatus — daemon route",
      "action": "call_tool",
      "name": "GetSyncStatus",
      "arguments": {"dialog_id": 12345},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "GetEntityInfo — resolve first, daemon not running so returns not-running message",
      "action": "call_tool",
      "name": "GetEntityInfo",
      "arguments": {"entity": "nonexistent_test_entity_12345"},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "GetInbox — daemon route",
      "action": "call_tool",
      "name": "GetInbox",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": ["not running", "mcp-telegram sync"]
      }
    },
    {
      "_comment": "GetUsageStats — analytics.db, works without daemon",
      "action": "call_tool",
      "name": "GetUsageStats",
      "arguments": {},
      "expect": {
        "is_error": false
      }
    }
  ]
}
