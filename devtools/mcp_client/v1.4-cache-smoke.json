{
  "steps": [
    {
      "_comment": "Test 1: ListDialogs — META-01 (members=N) and META-02 (created=YYYY-MM-DD) for groups/channels",
      "action": "call_tool",
      "name": "ListDialogs",
      "arguments": {},
      "expect": {
        "is_error": false,
        "content_text_contains": [
          "members=",
          "created="
        ]
      }
    },
    {
      "_comment": "Test 2: ListMessages page 1 — cache population (CACHE-05), should return messages and navigation token",
      "action": "call_tool",
      "name": "ListMessages",
      "arguments": {
        "dialog": "Studio Robots and Inbox",
        "limit": 5
      },
      "expect": {
        "is_error": false,
        "content_text_contains": [
          "next_navigation:"
        ]
      }
    },
    {
      "_comment": "Test 3: ListMessages oldest — PRE-03 triggers prefetch forward from oldest",
      "action": "call_tool",
      "name": "ListMessages",
      "arguments": {
        "dialog": "Studio Robots and Inbox",
        "navigation": "oldest",
        "limit": 5
      },
      "expect": {
        "is_error": false,
        "content_text_contains": [
          "next_navigation:"
        ]
      }
    },
    {
      "_comment": "Test 4: ListMessages larger batch — look for [edited marker (EDIT-03, best-effort)",
      "action": "call_tool",
      "name": "ListMessages",
      "arguments": {
        "dialog": "Saved Messages",
        "limit": 50
      },
      "expect": {
        "is_error": false
      }
    },
    {
      "_comment": "Test 5: SearchMessages — always live (BYP-04), results written to cache (CACHE-05)",
      "action": "call_tool",
      "name": "SearchMessages",
      "arguments": {
        "dialog": "Studio Robots and Inbox",
        "query": "test",
        "limit": 3
      },
      "expect": {
        "is_error": false
      }
    },
    {
      "_comment": "Test 6: ListUnreadMessages — always live (BYP-03)",
      "action": "call_tool",
      "name": "ListUnreadMessages",
      "arguments": {},
      "expect": {
        "is_error": false
      }
    },
    {
      "_comment": "Test 7: ListMessages unread=true — bypass cache (BYP-02)",
      "action": "call_tool",
      "name": "ListMessages",
      "arguments": {
        "dialog": "Saved Messages",
        "unread": true,
        "limit": 5
      },
      "expect": {
        "is_error": false
      }
    }
  ]
}
